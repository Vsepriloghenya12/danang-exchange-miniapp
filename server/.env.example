# Bot
BOT_TOKEN=123:ABC

# Кто владелец (tg_id). Можно оставить пустым и узнать через /whoami
# Один владелец (старый формат)
OWNER_TG_ID=

# Несколько владельцев (новый формат): "111,222,333"
OWNER_TG_IDS=

# URL мини-приложения (HTTPS!), например https://xxxx.ngrok-free.app
WEBAPP_URL=

# Группы Telegram:
# 1) группа для публикации курса (кнопка "Опубликовать")
GROUP_CHAT_ID=

# 2) группа для заявок клиентов (кнопка "Отправить заявку")
REQUESTS_GROUP_CHAT_ID=

# Отдельная админка на ПК: https://<domain>/admin
# Задай длинный секретный ключ. В админке вводишь его для входа.
ADMIN_WEB_KEY=

# Сервер
PORT=4000
